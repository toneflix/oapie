{
    "name": "oapie",
    "type": "module",
    "version": "0.1.20",
    "description": "A CLI tool to extract OpenAPI specifications from documentations generated by readme.com and other similar platforms, and generate TypeScript SDKs for seamless API integration.",
    "main": "bin/cli.mjs",
    "private": false,
    "homepage": "https://oapi-extractor.toneflix.net",
    "repository": {
        "url": "https://github.com/toneflix/oapi-extractor.git",
        "type": "git"
    },
    "publishConfig": {
        "access": "public"
    },
    "bin": {
        "oapie": "bin/cli.mjs"
    },
    "exports": {
        ".": "./bin/cli.mjs"
    },
    "files": [
        "bin",
        "bin/cli.mjs"
    ],
    "keywords": [
        "oapie",
        "cli",
        "command-line",
        "tool",
        "integration",
        "sdk",
        "api",
        "developer",
        "h3ravel",
        "toneflix",
        "arkstack",
        "openapi",
        "specification",
        "readme.com",
        "documentation",
        "typescript",
        "extractor",
        "generator",
        "automation"
    ],
    "scripts": {
        "test": "pnpm run vitest --run",
        "test:watch": "pnpm vitest",
        "lint": "eslint . --ext .ts --ext .js",
        "cmd": "tsx src/cli.ts",
        "build": "tsdown",
        "version": "pnpm run build",
        "unlink": "pnpm uninstall --global oapie || true",
        "release": "pnpm changeset version && pnpm changeset publish",
        "publish-it": "pnpm publish --tag latest",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "preuninstall": "node ./uninstall.js",
        "prepublishOnly": "pnpm build"
    },
    "dependencies": {
        "@h3ravel/musket": "^0.10.1",
        "@h3ravel/shared": "^0.30.3",
        "cli-table3": "^0.6.5",
        "dotenv": "^17.2.3",
        "happy-dom": "^20.8.9",
        "tsdown": "^0.20.1"
    },
    "devDependencies": {
        "@changesets/cli": "^2.29.5",
        "@eslint/js": "^9.39.2",
        "@eslint/markdown": "^7.5.1",
        "@types/node": "^20.14.5",
        "eslint": "^9.39.2",
        "tsx": "^4.20.3",
        "typescript": "^5.4.5",
        "typescript-eslint": "^8.53.0",
        "vite-tsconfig-paths": "^5.1.4",
        "vitepress": "^1.5.0",
        "vitest": "^3.2.4",
        "vue": "^3.5.13"
    }
}