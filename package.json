{
    "name": "oapiex",
    "type": "module",
    "version": "0.3.7",
    "description": "CLI and TypeScript toolkit for turning documentation pages into usable developer artifacts.",
    "main": "./dist/index.cjs",
    "private": false,
    "homepage": "https://toneflix.github.io/oapiex",
    "repository": {
        "url": "https://github.com/toneflix/oapiex.git",
        "type": "git"
    },
    "publishConfig": {
        "access": "public"
    },
    "bin": {
        "oapie": "bin/cli.mjs",
        "oapiex": "bin/cli.mjs"
    },
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "bin",
        "dist"
    ],
    "keywords": [
        "oapie",
        "oapiex",
        "cli",
        "command-line",
        "tool",
        "integration",
        "sdk",
        "api",
        "developer",
        "h3ravel",
        "toneflix",
        "arkstack",
        "openapi",
        "specification",
        "readme.com",
        "documentation",
        "typescript",
        "extractor",
        "generator",
        "automation"
    ],
    "scripts": {
        "test": "pnpm vitest --run",
        "test:watch": "pnpm vitest",
        "lint": "eslint . --ext .ts --ext .js",
        "oapie": "node --import tsx src/cli.ts",
        "build": "tsdown",
        "version": "pnpm run build",
        "unlink": "pnpm uninstall --global oapiex || true",
        "barrel": "pnpm -r --filter \"./packages/*\" barrel && pnpm barrelize",
        "coverage": "pnpm vitest --run --coverage",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "version:packages": "pnpm -r --filter \"@oapiex/*\" version:patch && git add . && git commit -m \"chore: bump package versions\"",
        "publish:packages": "pnpm version:packages && pnpm -r --filter \"@oapiex/*\" publish --access public",
        "docs:preview": "vitepress preview docs",
        "preuninstall": "node ./uninstall.js",
        "prepublishOnly": "pnpm build"
    },
    "dependencies": {
        "@h3ravel/musket": "^0.10.1",
        "@h3ravel/shared": "^0.30.3",
        "@happy-dom/server-renderer": "^20.8.9",
        "axios": "^1.14.0",
        "happy-dom": "^20.8.9",
        "jiti": "^2.6.1",
        "jsdom": "^29.0.1",
        "prettier": "^3.8.1",
        "puppeteer": "^24.40.0",
        "tsdown": "^0.20.1"
    },
    "devDependencies": {
        "@changesets/cli": "^2.29.5",
        "@eslint/js": "^9.39.2",
        "@eslint/markdown": "^7.5.1",
        "@types/jsdom": "^28.0.1",
        "@types/node": "^20.14.5",
        "@vitest/coverage-v8": "3.2.4",
        "barrelize": "^1.7.4",
        "eslint": "^9.39.2",
        "tsx": "^4.20.3",
        "typescript": "^5.4.5",
        "typescript-eslint": "^8.53.0",
        "vitepress": "^1.5.0",
        "vitest": "^3.2.4",
        "vue": "^3.5.13"
    }
}
